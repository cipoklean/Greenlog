# ── LLM providers ──────────────────────────────────────────────
# Primary provider (drives which one is tried first). Default: gemini.
# When the primary fails with a retriable error (429 / 401 / 403 / 5xx /
# timeout), the next configured provider is tried automatically.
LLM_PROVIDER=gemini

# Gemini (default primary, vision-capable).
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Optional model override:
# GEMINI_MODEL=gemini-3.1-flash-lite

# Groq (fallback, text-only — vision requests skip it).
# Leave unset to disable the fallback chain.
# GROQ_API_KEY=YOUR_GROQ_API_KEY
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Slack (required for npm start) ─────────────────────────────
SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN
SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN

# ── Optional app config ────────────────────────────────────────
# Default channel for the weekly digest (env fallback).
# GREENLOG_DIGEST_CHANNEL=C0123456789
# Default timezone for week boundaries (env fallback).
# GREENLOG_TZ=UTC
# HTTP keep-alive port (default: 3000).
# PORT=3000
