  "dependencies": {
    "@slack/bolt": "^4.7.3",
    "dotenv": "~17.4.2",
    "node-cron": "^4.2.1",
    "openai": "^6.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@slack/cli-hooks": "^1.3.2",
    "typescript": "^6.0.3"
  }
}
